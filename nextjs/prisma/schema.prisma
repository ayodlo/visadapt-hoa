generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BOARD_MEMBER
  RESIDENT
}

model Community {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  communityAssignments  CommunityAssignment[]
  properties            Property[]
  vendors               Vendor[]
  announcements         Announcement[]
  events                Event[]
  issues                Issue[]
  documents             Document[]
  polls                 Poll[]
  architecturalRequests ArchitecturalRequest[]
  violations            Violation[]
  charges               Charge[]
  payments              Payment[]
  duesRecords           DuesRecord[]
  maintenanceRequests   MaintenanceRequest[]
  auditLogs             AuditLog[]

  @@map("communities")
}

// Multi-community access for ADMIN and BOARD_MEMBER (assigned by SUPER_ADMIN).
// SUPER_ADMIN needs no rows here — it can select any community, unrestricted.
// RESIDENT doesn't use this either — see User.communityId, its one fixed community.
model CommunityAssignment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId  String
  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedBy   User?     @relation("CommunityAssignmentsMade", fields: [assignedById], references: [id])
  createdAt    DateTime  @default(now())

  @@unique([userId, communityId])
  @@map("community_assignments")
}

model User {
  id                   String                @id @default(cuid())
  firstName            String
  lastName             String
  email                String                @unique
  passwordHash         String
  role                 UserRole              @default(RESIDENT)
  // Fixed home community for RESIDENT; null for ADMIN/BOARD_MEMBER/SUPER_ADMIN,
  // who use CommunityAssignment (multi-community) instead.
  communityId          String?
  community            Community?            @relation(fields: [communityId], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  communityAssignments     CommunityAssignment[]
  communityAssignmentsMade CommunityAssignment[] @relation("CommunityAssignmentsMade")
  properties              Property[]
  residentProfile         ResidentProfile?
  createdAnnouncements    Announcement[]
  announcementReads       AnnouncementRead[]
  maintenanceRequests     MaintenanceRequest[]
  events               Event[]
  polls                Poll[]
  pollVotes            PollVote[]
  duesRecords          DuesRecord[]
  documents            Document[]
  charges              Charge[]
  payments             Payment[]
  auditLogs            AuditLog[]
  pushTokens           PushToken[]
  passwordResetTokens  PasswordResetToken[]
  issues               Issue[]              @relation("ResidentIssues")
  assignedIssues       Issue[]              @relation("AssignedIssues")
  issueComments        IssueComment[]
  issueActivities      IssueActivity[]
  architecturalRequests          ArchitecturalRequest[]          @relation("ResidentArchRequests")
  architecturalRequestComments   ArchitecturalRequestComment[]   @relation("ArchRequestComments")
  architecturalRequestActivities ArchitecturalRequestActivity[]  @relation("ArchRequestActivities")
  violations                     Violation[]                     @relation("ResidentViolations")
  createdViolations              Violation[]                     @relation("CreatedViolations")
  violationComments              ViolationComment[]
  violationActivities            ViolationActivity[]
  violationAppeals               ViolationAppeal[]               @relation("AppealSubmitter")
  reviewedAppeals                ViolationAppeal[]               @relation("AppealReviewer")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

model Property {
  id            String   @id @default(cuid())
  streetAddress String
  unitNumber    String?
  city          String
  state         String
  zipCode       String
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  communityId   String
  community     Community @relation(fields: [communityId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  charges                Charge[]
  payments               Payment[]
  issues                 Issue[]
  architecturalRequests  ArchitecturalRequest[]
  violations             Violation[]

  @@index([communityId])
  @@map("properties")
}

model ResidentProfile {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])
  phone      String?
  moveInDate DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("resident_profiles")
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  category    String?
  notes       String?
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  issues      Issue[]

  @@index([communityId])
  @@map("vendors")
}

// ─── Issue Tracking ───────────────────────────────────────────────────────────

enum IssueCategory {
  LANDSCAPING
  MAINTENANCE
  PARKING
  SAFETY
  NOISE
  GATE_ACCESS
  TRASH
  OTHER
}

enum IssueStatus {
  SUBMITTED
  UNDER_REVIEW
  ASSIGNED
  IN_PROGRESS
  WAITING_ON_VENDOR
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Issue {
  id                   String          @id @default(cuid())
  residentId           String
  resident             User            @relation("ResidentIssues", fields: [residentId], references: [id])
  propertyId           String?
  property             Property?       @relation(fields: [propertyId], references: [id])
  vendorId             String?
  vendor               Vendor?         @relation(fields: [vendorId], references: [id])
  assignedToId         String?
  assignedTo           User?           @relation("AssignedIssues", fields: [assignedToId], references: [id])
  communityId          String
  community            Community       @relation(fields: [communityId], references: [id])
  category             IssueCategory   @default(OTHER)
  title                String
  description          String
  location             String
  priority             IssuePriority   @default(MEDIUM)
  status               IssueStatus     @default(SUBMITTED)
  preferredContactMethod String
  dueDate              DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  comments             IssueComment[]
  activities           IssueActivity[]

  @@index([communityId])
  @@map("issues")
}

model IssueComment {
  id         String   @id @default(cuid())
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("issue_comments")
}

model IssueActivity {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@map("issue_activities")
}

model AuditLog {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime   @default(now())

  @@index([communityId])
  @@map("audit_logs")
}

model PushToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt

  @@index([userId])
  @@map("push_tokens")
}

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  EMERGENCY
}

enum AnnouncementAudience {
  ALL_RESIDENTS
  BOARD_MEMBERS
  SPECIFIC_LOCATION
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  body           String
  priority       AnnouncementPriority @default(NORMAL)
  audience       AnnouncementAudience @default(ALL_RESIDENTS)
  targetLocation String?
  isPinned       Boolean              @default(false)
  publishAt      DateTime             @default(now())
  expiresAt      DateTime?
  createdById    String
  createdBy      User                 @relation(fields: [createdById], references: [id])
  communityId    String
  community      Community            @relation(fields: [communityId], references: [id])
  reads          AnnouncementRead[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([communityId])
  @@map("announcements")
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@map("announcement_reads")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([communityId])
  @@map("events")
}

model MaintenanceRequest {
  id            String          @id @default(cuid())
  title         String
  description   String
  status        RequestStatus   @default(OPEN)
  priority      RequestPriority @default(MEDIUM)
  submittedById String
  submittedBy   User            @relation(fields: [submittedById], references: [id])
  communityId   String
  community     Community       @relation(fields: [communityId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([communityId])
  @@map("maintenance_requests")
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Document {
  id           String           @id @default(cuid())
  title        String
  description  String?
  category     DocumentCategory @default(OTHER)
  fileUrl      String
  fileName     String
  uploadedById String
  uploadedBy   User             @relation(fields: [uploadedById], references: [id])
  communityId  String
  community    Community        @relation(fields: [communityId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([communityId])
  @@map("documents")
}

enum DocumentCategory {
  CC_AND_RS
  RULES_AND_REGS
  MEETING_MINUTES
  FINANCIALS
  INSURANCE
  COMMUNITY_FORMS
  MAINTENANCE
  OTHER
}

model DuesRecord {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  communityId  String
  community    Community  @relation(fields: [communityId], references: [id])
  label        String
  amountCents  Int
  dueDate      DateTime
  status       DuesStatus @default(PENDING)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([communityId])
  @@map("dues_records")
}

enum DuesStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

model Charge {
  id          String       @id @default(cuid())
  residentId  String
  resident    User         @relation(fields: [residentId], references: [id])
  propertyId  String?
  property    Property?    @relation(fields: [propertyId], references: [id])
  communityId String
  community   Community    @relation(fields: [communityId], references: [id])
  description String
  amount      Int
  dueDate     DateTime
  status      ChargeStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@index([communityId])
  @@map("charges")
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
}

model Payment {
  id                 String        @id @default(cuid())
  residentId         String
  resident           User          @relation(fields: [residentId], references: [id])
  propertyId         String?
  property           Property?     @relation(fields: [propertyId], references: [id])
  communityId        String
  community          Community     @relation(fields: [communityId], references: [id])
  amount             Int
  paymentMethod      String
  status             PaymentStatus @default(PAID)
  paidAt             DateTime?
  confirmationNumber String        @unique
  createdAt          DateTime      @default(now())

  @@index([communityId])
  @@map("payments")
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
}

model Poll {
  id          String       @id @default(cuid())
  question    String
  description String?
  closesAt    DateTime?
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  communityId String
  community   Community    @relation(fields: [communityId], references: [id])
  options     PollOption[]
  votes       PollVote[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([communityId])
  @@map("polls")
}

model PollOption {
  id     String     @id @default(cuid())
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  PollVote[]

  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([pollId, userId])
  @@map("poll_votes")
}

// ─── Architectural Review ─────────────────────────────────────────────────────

enum ArchitecturalRequestType {
  FENCE
  EXTERIOR_PAINT
  LANDSCAPING
  SOLAR
  ROOF
  SHED
  OTHER
}

enum ArchitecturalRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_MORE_INFORMATION
  APPROVED
  DENIED
  WITHDRAWN
}

model ArchitecturalRequest {
  id                     String                         @id @default(cuid())
  residentId             String
  resident               User                           @relation("ResidentArchRequests", fields: [residentId], references: [id])
  propertyId             String?
  property               Property?                      @relation(fields: [propertyId], references: [id])
  communityId            String
  community              Community                      @relation(fields: [communityId], references: [id])
  requestType            ArchitecturalRequestType
  description            String
  desiredStartDate       DateTime?
  status                 ArchitecturalRequestStatus     @default(DRAFT)
  governingRuleReference String?
  decisionReason         String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  comments               ArchitecturalRequestComment[]
  activities             ArchitecturalRequestActivity[]
  attachments            ArchitecturalRequestAttachment[]

  @@index([communityId])
  @@map("architectural_requests")
}

model ArchitecturalRequestComment {
  id        String               @id @default(cuid())
  requestId String
  request   ArchitecturalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User                 @relation("ArchRequestComments", fields: [authorId], references: [id])
  body      String
  isInternal Boolean             @default(false)
  createdAt DateTime             @default(now())

  @@map("architectural_request_comments")
}

model ArchitecturalRequestActivity {
  id        String               @id @default(cuid())
  requestId String
  request   ArchitecturalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?                @relation("ArchRequestActivities", fields: [actorId], references: [id])
  action    String
  details   String?
  createdAt DateTime             @default(now())

  @@map("architectural_request_activities")
}

model ArchitecturalRequestAttachment {
  id        String               @id @default(cuid())
  requestId String
  request   ArchitecturalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  label     String
  fileName  String?
  createdAt DateTime             @default(now())

  @@map("architectural_request_attachments")
}

// ─── Violations & Appeals ─────────────────────────────────────────────────────

enum ViolationType {
  LANDSCAPING_MAINTENANCE
  PARKING
  NOISE
  PROPERTY_APPEARANCE
  UNAUTHORIZED_MODIFICATION
  PET_VIOLATION
  TRASH_AND_DEBRIS
  OTHER
}

enum ViolationStatus {
  DRAFT
  NOTICE_SENT
  RESIDENT_RESPONDED
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum ViolationAppealStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
  WITHDRAWN
}

model Violation {
  id              String          @id @default(cuid())
  residentId      String
  resident        User            @relation("ResidentViolations", fields: [residentId], references: [id])
  propertyId      String?
  property        Property?       @relation(fields: [propertyId], references: [id])
  createdById     String
  createdBy       User            @relation("CreatedViolations", fields: [createdById], references: [id])
  communityId     String
  community       Community       @relation(fields: [communityId], references: [id])
  violationType   ViolationType
  ruleCitation    String
  description     String
  observedAt      DateTime
  deadline        DateTime?
  status          ViolationStatus @default(DRAFT)
  resolutionSteps String?
  evidenceUrl     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  comments        ViolationComment[]
  activities      ViolationActivity[]
  appeal          ViolationAppeal?

  @@index([communityId])
  @@map("violations")
}

model ViolationComment {
  id          String    @id @default(cuid())
  violationId String
  violation   Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  body        String
  isInternal  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("violation_comments")
}

model ViolationActivity {
  id          String    @id @default(cuid())
  violationId String
  violation   Violation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?     @relation(fields: [actorId], references: [id])
  action      String
  details     String?
  createdAt   DateTime  @default(now())

  @@map("violation_activities")
}

model ViolationAppeal {
  id           String               @id @default(cuid())
  violationId  String               @unique
  violation    Violation            @relation(fields: [violationId], references: [id], onDelete: Cascade)
  submittedById String
  submittedBy  User                 @relation("AppealSubmitter", fields: [submittedById], references: [id])
  reason       String
  status       ViolationAppealStatus @default(SUBMITTED)
  outcome      String?
  reviewedById String?
  reviewedBy   User?                @relation("AppealReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("violation_appeals")
}
