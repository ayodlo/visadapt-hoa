# ─── Database ───────────────────────────────────────────────────────────────
# Local (Docker):
# DATABASE_URL="postgresql://communityhq:communityhq_secret@localhost:5432/communityhq_dev?schema=public"
# Production (Neon): get this from your Neon project dashboard
DATABASE_URL="postgresql://user:pass@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Production URL of the deployed app (used in password reset emails and CORS)
APP_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified domain or use onboarding@resend.dev for testing
EMAIL_FROM=CommunityHQ <noreply@yourdomain.com>

# ─── File Storage (AWS S3) ──────────────────────────────────────────────────
# Create an S3 bucket and an IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=your-bucket-name

# ─── Local dev Postgres (Docker) ────────────────────────────────────────────
POSTGRES_USER=communityhq
POSTGRES_PASSWORD=communityhq_secret
POSTGRES_DB=communityhq_dev
POSTGRES_PORT=5432
